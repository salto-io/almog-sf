    }
    output_schema_json@dv = {
      source = file("salesforce/Records/GenAiFunction/Get_Account_Details/output/schema.json")
      filePath = "genAiFunctions/Get_Account_Details/output/schema.json"
    }
  }
  _alias = "Get_Account_Details"
}
