  invocationTarget = salesforce.Flow.instance.Get_Account_Details
  invocationTargetType = "flow"
  isConfirmationRequired = false
  masterLabel = "Get Account Details"
  fullName = "Get_Account_Details"
  schemas = {
    input_schema_json@dv = {
      source = file("salesforce/Records/GenAiFunction/Get_Account_Details/input/schema.json")
